# Copy to apps/web/.env.local for local development (Next.js + Convex CLI).
# The realtime server also reads apps/web/.env.local, then repo-root .env.local.

# --- Convex ---
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Set after `npx convex dev` links a project (from apps/web):
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# --- Shared (web + realtime) ---
HOST_JWT_SECRET=

# --- Web / Auth.js / Twitch ---
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
AUTH_TWITCH_ID=
AUTH_TWITCH_SECRET=

# --- Realtime (local) ---
PORT=3001
CORS_ORIGIN=http://localhost:3000

# --- Production overrides (uncomment on deploy hosts only) ---
# NEXT_PUBLIC_REALTIME_URL=https://realtime.yourdomain.com
# CORS_ORIGIN=https://your-web-app.vercel.app
